# ── Video Providers ───────────────────────────────────────────
# Configure at least one provider. Only set the ones you want to use.

# CogVideoX (智谱清影) - FREE unlimited ← recommended starting point
# Get key at: https://open.bigmodel.cn
COGVIDEO_API_KEY=your_cogvideo_api_key

# Alibaba DashScope / Wan (通义万相) - 50s free (90 days)
# Get key at: https://bailian.console.aliyun.com
# DASHSCOPE_API_KEY=your_dashscope_api_key

# Kling AI (可灵) - 66 credits/day (web only, API requires resource pack)
# Get keys at: https://klingai.com/global/dev
# KLING_ACCESS_KEY=your_kling_access_key
# KLING_SECRET_KEY=your_kling_secret_key

# SiliconFlow (硅基流动) - $1 registration bonus
# Get key at: https://siliconflow.cn
# SILICONFLOW_API_KEY=your_siliconflow_api_key

# Vidu (生数科技) - Promotional free credits
# Get key at: https://platform.vidu.com
# VIDU_API_KEY=your_vidu_api_key

# MiniMax Hailuo (海螺) - Paid (best quality among Chinese providers)
# Get key at: https://platform.minimaxi.com
# Also enables TTS (generate_speech) and Music (generate_music) tools
# MINIMAX_API_KEY=your_minimax_api_key
# MINIMAX_API_HOST=https://api.minimax.chat

# ── Google Veo (Vertex AI) ───────────────────────────────────
# Requires GCP project with billing + Vertex AI API enabled
# Auth: GEMINI_API_KEY (recommended) or ADC (gcloud auth application-default login)
# Install: uv sync --extra gcp
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_REGION=us-central1
# GEMINI_API_KEY=your_gcp_api_key
#
# Veo models:
#   veo-2.0-generate-001       — 720p, ~$0.50/sec (default, GA)
#   veo-3.0-generate-001       — 1080p, ~$0.75/sec (highest quality)
#   veo-3.0-fast-generate-001  — 1080p, ~$0.15/sec (best value) ← recommended
# VEO_MODEL=veo-2.0-generate-001
#
# Optional: GCS bucket for video output (omit for base64 inline)
# VEO_GCS_BUCKET=your-bucket-name

# ── Output ────────────────────────────────────────────────────
# Videos/audio auto-saved with timestamps, e.g. cogvideo_20260330_131442.mp4
# VIDEO_OUTPUT_DIR=./output
